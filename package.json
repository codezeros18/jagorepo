{
  "name": "jagarepo",
  "version": "0.1.0",
  "private": true,
  "description": "Cek dependency sebelum jadi celah.",
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev": "concurrently --names api,web --prefix-colors cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "npm run dev --workspace=server",
    "build:web": "npm run build --workspace=web",
    "build:api": "npm run build --workspace=server",
    "build": "npm run build:web && npm run build:api",
    "lint:web": "npm run lint --workspace=web",
    "lint:api": "npm run lint --workspace=server",
    "lint": "npm run lint:web && npm run lint:api",
    "start:web": "npm run start --workspace=web",
    "start:api": "npm run start --workspace=server"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
