# ============================================================
# JagaRepo — Environment Variables
# Salin file ini ke .env dan isi nilainya.
# Jangan commit .env ke repo.
# ============================================================

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DEMO_MODE=false

# --- Backend (Express) ---
API_PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- Database (opsional untuk MVP, skip jika pakai in-memory) ---
DATABASE_URL=postgresql://user:password@localhost:5432/jagarepo

# --- External APIs ---
OSV_API_BASE_URL=https://api.osv.dev
NPM_REGISTRY_BASE_URL=https://registry.npmjs.org
PYPI_API_BASE_URL=https://pypi.org/pypi

# --- PDF Storage ---
PDF_STORAGE_PATH=./storage/reports
